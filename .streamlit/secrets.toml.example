# ── Seamfix Dashboard Secrets ──
# Copy this file to secrets.toml and fill in the values.
# On Streamlit Cloud, add these in the app settings > Secrets.

# ── Authentication ──
# Google OAuth is configured in Streamlit Cloud app settings.
# The allowed_emails list below controls EXACTLY who can access.
# To add or remove users, just edit this list in Streamlit Cloud Secrets.

[auth]
# Explicit allowlist — ONLY these emails can access the dashboard.
# To grant access: add the email. To revoke: remove it.
allowed_emails = [
    "conwurah@gmail.com",
    "conwurah@seamfix.com",
    "fatube@seamfix.com",
    "lwilfred@seamfix.com",
    "obolade@seamfix.com",
    "cemewulu@seamfix.com",
    # Add more emails here...
]

# Fallback: if allowed_emails is empty, falls back to domain check
# allowed_domains = ["seamfix.com"]

# Option 2: Simple password (fallback if OAuth not configured)
# password = "your-secure-password-here"

# ── Google Cloud Service Account ──
# Required for BOTH:
#   • Live revenue data from Google Sheet
#   • Auto-fetching cash reports from Google Drive folder
#
# Setup steps:
#   1. Go to https://console.cloud.google.com
#   2. Create a project (or use existing)
#   3. Enable "Google Sheets API" and "Google Drive API"
#   4. Create a Service Account (IAM > Service Accounts)
#   5. Generate a JSON key
#   6. Share the Google Sheet with the service account email (Viewer)
#   7. Share the Google Drive folder with the service account email (Viewer)
#   8. Paste the JSON key fields below

# [gcp_service_account]
# type = "service_account"
# project_id = "your-project-id"
# private_key_id = "key-id"
# private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# client_email = "seamfix-dashboard@your-project.iam.gserviceaccount.com"
# client_id = "123456789"
# auth_uri = "https://accounts.google.com/o/oauth2/auth"
# token_uri = "https://oauth2.googleapis.com/token"
# auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
# client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/..."
