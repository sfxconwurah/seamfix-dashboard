# ── Seamfix Dashboard Secrets ──
# Copy this file to secrets.toml and fill in the values.
# On Streamlit Cloud, add these in the app settings > Secrets.

# ── Google OAuth Authentication ──
# Controls who can access the dashboard via Google sign-in.
# Uses a CUSTOM OAuth flow (NOT Streamlit's built-in [auth] which is broken).
#
# Setup:
#   1. Go to Google Cloud Console > APIs & Services > Credentials
#   2. Create OAuth 2.0 Client ID (Web application)
#   3. Add authorized redirect URI: https://seamfix-executive-dashboard.streamlit.app/
#   4. Copy client_id and client_secret below
#
# To add/remove users: edit the allowed_emails list below.

[google_oauth]
client_id = "your-google-oauth-client-id.apps.googleusercontent.com"
client_secret = "GOCSPX-your-client-secret"
redirect_uri = "https://seamfix-executive-dashboard.streamlit.app/"
allowed_emails = [
    "conwurah@gmail.com",
    "conwurah@seamfix.com",
    "fatube@seamfix.com",
    "lwilfred@seamfix.com",
    "obolade@seamfix.com",
    "cemewulu@seamfix.com",
    # Add more emails here...
]

# ── Anthropic API Key (for Bobby chat assistant) ──
ANTHROPIC_API_KEY = "sk-ant-api03-your-key-here"

# ── Google Cloud Service Account ──
# Required for:
#   • Live revenue data from Google Sheet
#   • Auto-fetching cash reports from Google Drive folder
#   • Bobby usage logging to Google Sheet
#
# Setup:
#   1. Go to https://console.cloud.google.com
#   2. Create a project (or use existing)
#   3. Enable "Google Sheets API" and "Google Drive API"
#   4. Create a Service Account (IAM > Service Accounts)
#   5. Generate a JSON key
#   6. Share the Revenue Google Sheet with the service account email (Viewer)
#   7. Share the Cash Reports Google Drive folder with the service account email (Viewer)
#   8. Share the Bobby Log Google Sheet with the service account email (Editor)
#   9. Paste the JSON key fields below

[gcp_service_account]
type = "service_account"
project_id = "your-project-id"
private_key_id = "key-id"
private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email = "seamfix-dashboard@your-project.iam.gserviceaccount.com"
client_id = "123456789"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/..."
